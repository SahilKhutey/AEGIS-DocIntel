# Environment
AMDI_ENV=development
AMDI_LOG_LEVEL=INFO
AMDI_SECRET_KEY=change-me-in-production

# API
AMDI_HOST=0.0.0.0
AMDI_PORT=8000
AMDI_WORKERS=4
AMDI_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Storage
AMDI_SQLITE_PATH=data/amdi.db
AMDI_DUCKDB_PATH=data/amdi.duckdb
AMDI_REDIS_URL=redis://localhost:6379/0
AMDI_QDRANT_URL=http://localhost:6333

# LLM
AMDI_LLM_PROVIDER=mock
AMDI_LLM_MODEL=gpt-4o
AMDI_LLM_ENDPOINT=
AMDI_LLM_API_KEY=
AMDI_OPENAI_API_KEY=
AMDI_ANTHROPIC_API_KEY=
AMDI_GOOGLE_API_KEY=

# Models
AMDI_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
AMDI_EMBEDDING_DIM=1024
AMDI_RERANKER_MODEL=BAAI/bge-reranker-large

# Compute
AMDI_DEVICE=cpu
AMDI_OCR_ENGINE=tesseract

# Context
AMDI_MAX_CONTEXT_TOKENS=4096
AMDI_TARGET_CONTEXT_TOKENS=1500
AMDI_TOP_K=12
